{
  "info": {
    "name": "Escola_cafecombug API",
    "description": "Coleção Postman completa da Escola.API com suporte a autenticação Bearer Token e endpoints validados.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://localhost:5001/api",
      "type": "string"
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Usuarios",
      "description": "Gerenciamento de usuários e autenticação",
      "item": [
        {
          "name": "Registrar Novo Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Usuário criado com sucesso', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "const token = jsonData.token;",
                  "",
                  "pm.test('Token JWT presente na resposta', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "if (token) {",
                  "    pm.collectionVariables.set('bearerToken', token);",
                  "    console.log('Bearer Token salvo: ' + token.substring(0, 20) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"João Silva\",\n  \"email\": \"joao.silva@exemplo.com\",\n  \"senha\": \"senhaForte123\"\n}"
            },
            "url": "{{baseUrl}}/usuario"
          }
        },
        {
          "name": "Login Usuario",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login retornou sucesso', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const jsonData = pm.response.json();",
                  "const token = jsonData.token;",
                  "",
                  "pm.test('Token JWT presente na resposta', function () {",
                  "    pm.expect(token).to.be.a('string').and.not.empty;",
                  "});",
                  "",
                  "if (token) {",
                  "    pm.collectionVariables.set('bearerToken', token);",
                  "    console.log('Bearer Token salvo com sucesso');",
                  "} else {",
                  "    console.log('Resposta:', JSON.stringify(jsonData, null, 2));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao.silva@exemplo.com\",\n  \"senha\": \"senhaForte123\"\n}"
            },
            "url": "{{baseUrl}}/usuario/login"
          }
        }
      ]
    },
